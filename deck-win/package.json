{
  "name": "deck-os-win",
  "version": "1.0.0",
  "description": "Deck OS — JARVIS Command Center (Windows desktop app)",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:portable": "electron-builder --win portable --x64"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.decin.roberts.deckos",
    "productName": "Deck OS",
    "copyright": "Copyright © 2025 Devin C Roberts",
    "directories": {
      "output": "dist-win"
    },
    "files": [
      "main.js",
      "preload.js",
      "build/**/*",
      "api-dist/**/*",
      "frontend-dist/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.png",
      "uninstallerIcon": "build/icon.png",
      "shortcutName": "Deck OS"
    },
    "extraResources": [
      { "from": "api-dist", "to": "api-dist" },
      { "from": "frontend-dist", "to": "frontend-dist" }
    ]
  }
}
