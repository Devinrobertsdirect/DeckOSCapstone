# ────────────────────────────────────────────────────────────────────────────
# DeckOS — Environment Variables Reference
# Copy this file to .env and fill in your values before running locally.
# ────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/deckos

# ── API Server ────────────────────────────────────────────────────────────────
# Port the Express API server listens on (default: 8080)
PORT=8080

# Node environment (development | production)
NODE_ENV=development

# ── Local LLM Model Routing ───────────────────────────────────────────────────
# DeckOS uses a 3-tier model routing gateway. Each task type is automatically
# sent to the right model based on cognitive load:
#
#   CORTEX  (Thinking layer)  — chat, reasoning, planning, summarization, briefings
#   REFLEX  (Fast layer)      — classification, routing, commands, quick responses
#   AUTOPILOT (Rule engine)   — system checks, device polling, deterministic fallback
#
# These must match the model names in your local Ollama installation.
# Check what you have: ollama list
# Pull Gemma 3 9B:          ollama pull gemma3:9b
# Pull phi3:                ollama pull phi3
#
REASONING_MODEL=gemma3:9b
FAST_MODEL=phi3

# ── AI / LLM Cloud (Optional) ─────────────────────────────────────────────────
# Used for TTS, STT, and vision endpoints only.
# Leave blank if running fully local with Ollama.
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Anthropic Claude (if configured in ai-router)
ANTHROPIC_API_KEY=sk-ant-...

# ── WhatsApp / Twilio ─────────────────────────────────────────────────────────
# Required only if you use the WhatsApp channel integration
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Hardware Integrations ─────────────────────────────────────────────────────
# MQTT broker URL (leave blank to run in simulation-only mode)
MQTT_BROKER_URL=

# Port for WebSocket device transport (leave blank to disable real device connections)
WS_DEVICE_PORT=

# ── Debug ─────────────────────────────────────────────────────────────────────
# Set to "true" to enable verbose trace logging
TRACE_MODE=false

# ── Session Security ──────────────────────────────────────────────────────────
# Secret used for signing session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars
