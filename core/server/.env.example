# MQTT broker URL — required for real IoT device connectivity.
# Set this as a Replit Secret (not a plain env var) so it is never committed.
#
# Examples:
#   Public test broker (development only — unauthenticated, shared):
#     MQTT_BROKER_URL=mqtt://broker.hivemq.com:1883
#
#   Private broker with authentication (recommended for production):
#     MQTT_BROKER_URL=mqtt://username:password@your-broker.example.com:1883
#
#   HiveMQ Cloud (free tier, TLS):
#     MQTT_BROKER_URL=mqtts://your-cluster.s1.eu.hivemq.cloud:8883
#
# Without this secret the server runs in simulation-only mode
# (simulated devices still work, real hardware cannot connect).
MQTT_BROKER_URL=

# ── Cloud AI — Anthropic Claude (APEX tier) ──────────────────────────────────
# ANTHROPIC_API_KEY is set in the root .env (or Settings UI) — not duplicated here.

# [OPTIONAL] Claude model for the APEX tier — "big-brain mode" for deep reasoning.
CLAUDE_MODEL=claude-sonnet-5

# [OPTIONAL] Cloud routing preference: local-first | cloud-first | local-only.
CLOUD_PREFERENCE=local-first

# [OPTIONAL] Max output tokens per Claude (APEX) request.
CLAUDE_MAX_TOKENS=4096

# ── Cloud AI — Additional Providers ──────────────────────────────────────────
# [OPTIONAL] Google Gemini API key. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# [OPTIONAL] Perplexity API key for real-time, cited web answers (Sonar models).
PERPLEXITY_API_KEY=

# ── Media Generation — Midjourney / Higgsfield ────────────────────────────────
# [OPTIONAL] Midjourney API key for image generation.
MIDJOURNEY_API_KEY=
# [OPTIONAL] Higgsfield API key for video / motion generation.
HIGGSFIELD_API_KEY=

# Interactive speed: "fast" (default, prefers Haiku/fast models) or "quality"
SPEED_MODE=fast
