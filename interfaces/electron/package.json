{
  "name": "neura-desktop",
  "version": "1.0.0",
  "description": "Neura — your own neural network, with a face. Cross-platform desktop app.",
  "main": "main.js",
  "private": true,
  "author": { "name": "Devberri LLC", "email": "support@developmentindustries.org" },
  "homepage": "https://developmentindustries.org",
  "scripts": {
    "start": "electron .",
    "stage": "node scripts/pack.mjs --stage-only",
    "pack": "node scripts/pack.mjs",
    "pack:win": "node scripts/pack.mjs --win",
    "pack:mac": "node scripts/pack.mjs --mac",
    "pack:linux": "node scripts/pack.mjs --linux",
    "pack:dir": "node scripts/pack.mjs --dir"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.devberri.neura",
    "productName": "Neura",
    "copyright": "Copyright © 2026 Devberri LLC",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist-out",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "build/**/*",
      "api-dist/**/*",
      "frontend-dist/**/*"
    ],
    "extraResources": [
      { "from": "api-dist", "to": "api-dist" },
      { "from": "frontend-dist", "to": "frontend-dist" }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64", "ia32"] },
        { "target": "portable", "arch": ["x64", "ia32"] }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Neura",
      "artifactName": "${productName}-${version}-setup-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable-${arch}.${ext}"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["universal"] },
        { "target": "zip", "arch": ["universal"] }
      ],
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Neura ${version}"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "category": "Utility",
      "icon": "build/icon.png",
      "maintainer": "Devberri LLC"
    },
    "publish": null
  }
}
